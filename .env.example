# Korea Investment Securities API
# 모의투자 (Paper Trading)
KIS_APP_KEY=your_paper_trading_app_key_here
KIS_APP_SECRET=your_paper_trading_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here
KIS_IS_PAPER_TRADING=true

# 실전투자 (Live Trading) - 1개월 후 전환
# KIS_APP_KEY=your_live_app_key_here
# KIS_APP_SECRET=your_live_app_secret_here
# KIS_ACCOUNT_NO=your_live_account_number_here
# KIS_IS_PAPER_TRADING=false

# 알림 설정 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 로그 레벨
LOG_LEVEL=INFO
